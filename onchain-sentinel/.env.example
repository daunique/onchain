# ─────────────────────────────────────────────
#  ONCHAIN SENTINEL — Environment Configuration
# ─────────────────────────────────────────────

# Telegram Bot (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Alchemy API (free tier at alchemy.com)
ALCHEMY_API_KEY=your_alchemy_api_key_here
ALCHEMY_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here

# Etherscan API (free tier at etherscan.io)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Token to Monitor (add your target token contract address)
TOKEN_CONTRACT_ADDRESS=0xYourTokenContractAddressHere
TOKEN_SYMBOL=TOKEN
TOKEN_CHAIN=ethereum

# Network RPC fallback (public free RPC)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here

# Flask Dashboard
FLASK_SECRET_KEY=change_this_to_a_random_secret_string
DASHBOARD_PORT=5000

# Alert Thresholds
MIN_CONFIDENCE_TO_ALERT=medium
# Options: low, medium, high
