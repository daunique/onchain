# ── OnChain Sentinel v2 — Full Autonomous Mode ──────────────────────────────

# Telegram (get from @BotFather → /newbot, then @userinfobot for chat ID)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Alchemy — free at alchemy.com (create app → Ethereum Mainnet)
ALCHEMY_API_KEY=your_alchemy_api_key
ALCHEMY_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key
ALCHEMY_HTTP_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key

# Etherscan — free at etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key

# DexScreener — no key needed (free public API)
# CoinGecko   — no key needed (free public API)

# Scanner settings
SCAN_INTERVAL_MINUTES=30          # How often to scan for new suspicious tokens
MIN_PRICE_CHANGE_PCT=15           # Min % pump to flag as a pump/dump event
MIN_PUMP_EVENTS=2                 # Min number of pump/dump cycles to investigate
LOOKBACK_DAYS=30                  # How many days of history to analyse per token
MAX_TOKENS_TO_SCAN=20             # Tokens checked per scan cycle

# Clustering settings
MIN_CLUSTER_SIZE=2                # Min wallets to form a suspicious cluster
GAS_FUZZY_TOLERANCE_PCT=5         # ±% tolerance for fuzzy gas matching

# Alerts
MIN_CONFIDENCE_TO_ALERT=medium    # low | medium | high

# Dashboard
DASHBOARD_PORT=5000
FLASK_SECRET_KEY=change_me_to_random_string
