# ── OnChain Sentinel v3 — ETH + Base, sub-$20M cap ──────────────────────────

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Alchemy — Ethereum Mainnet (existing)
ALCHEMY_API_KEY=your_alchemy_api_key
ALCHEMY_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key
ALCHEMY_HTTP_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key

# Alchemy — Base Mainnet (NEW: create a Base app in Alchemy dashboard)
# alchemy.com → Create App → Network: Base Mainnet
ALCHEMY_BASE_WS_URL=wss://base-mainnet.g.alchemy.com/v2/your_alchemy_api_key
ALCHEMY_BASE_HTTP_URL=https://base-mainnet.g.alchemy.com/v2/your_alchemy_api_key

# Etherscan — works for both Ethereum AND Base (same key, Basescan is Etherscan family)
ETHERSCAN_API_KEY=your_etherscan_api_key

# DexScreener — no key needed (free public API, covers ETH + Base)
# DeFiLlama  — no key needed (free public API, covers ETH + Base)
# CoinGecko  — no key needed (single trending call only, no per-coin lookups)

# Scanner settings
SCAN_INTERVAL_MINUTES=10
MIN_PRICE_CHANGE_PCT=15
MAX_TOKENS_TO_SCAN=50           # raised from 20 — now scanning 2 chains
MAX_MARKET_CAP_USD=20000000     # $20M hard ceiling (NEW)
LOOKBACK_DAYS=30

# Clustering
MIN_CLUSTER_SIZE=2
GAS_FUZZY_TOLERANCE_PCT=5

# Alerts
MIN_CONFIDENCE_TO_ALERT=medium  # low | medium | high

# Dashboard
DASHBOARD_PORT=5000
FLASK_SECRET_KEY=change_me_to_random_string

# Workers
MAX_ANALYZER_WORKERS=3
PYTHONUNBUFFERED=1
